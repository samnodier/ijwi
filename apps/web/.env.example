# Frontend environment variables
# Copy to .env.local and fill in values

# Base URL of the deployed backend API (e.g. https://ijwi-api.onrender.com).
# When unset, it defaults to "/api" which relies on the Vite dev proxy (dev only).
# VITE_API_URL=https://ijwi-api.onrender.com

# Set to "true" to call the real backend AI analyze endpoint instead of the mock.
# When unset (or any other value), the frontend uses the mock analyzer.
# VITE_USE_REAL_API=true
