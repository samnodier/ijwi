# Neon Postgres connection string (from the Neon dashboard).
# Use the pooled connection string for serverless / HTTP driver.
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# Server
PORT=3000
# CORS: comma-separated list of allowed frontend origins, e.g.
# https://ijwi.vercel.app  (leave blank to allow all origins — fine for dev/demo)
CORS_ORIGIN=""

# Cloudinary (image/video storage)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1h"
# Google Sign-In: OAuth 2.0 Web client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=""

# ── AI service (apps/ai-service) ───────────────────────────────
# When set, the backend calls it to classify reports from photos + text.
# Leave blank to route using the citizen-provided category instead.
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="dev-internal-secret-change-me"
# Escape hatch: set to "true" to "pause" AI classification entirely. The report
# is still ALWAYS dispatched, routed by the citizen-provided category instead.
DISABLE_AI="false"

# ── Alert delivery (dispatch of report context to authorities) ─
# Provider precedence: Africa's Talking > Twilio > log-only.
#
# Africa's Talking (recommended for Rwanda). Key from https://account.africastalking.com
AT_API_KEY=""
# Use "sandbox" to test (messages go to the AT simulator), or your live app
# username for real delivery to Rwandan numbers.
AT_USERNAME="sandbox"
# Optional sender ID / short code (leave blank on sandbox).
AT_FROM=""

# Twilio (fallback / non-Rwanda). Only used if AT_API_KEY is empty.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# For SMS: a Twilio phone number, e.g. +14155551234
# For WhatsApp sandbox: whatsapp:+14155238886
TWILIO_FROM=""
# Force channel: "sms" or "whatsapp" (auto-detected if TWILIO_FROM starts with whatsapp:)
NOTIFY_CHANNEL="sms"

# DEMO ONLY: route every alert to this phone (E.164, e.g. +2507XXXXXXXX)
# regardless of authority, so you can showcase delivery to your own number.
# Leave blank in production.
DEMO_PHONE=""
