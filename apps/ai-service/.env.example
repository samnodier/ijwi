# Which provider to use: rules | groq
AI_PROVIDER=rules

# Groq (free tier, vision-capable). Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Vision-capable model. Scout is fast + free-tier friendly.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Shared secret the Node worker sends in X-Internal-Secret
AI_SERVICE_SECRET=dev-internal-secret-change-me

# Port the service listens on
PORT=8000
